{
  "name": "opencode-supabase",
  "version": "0.5.0",
  "type": "module",
  "description": "OpenCode plugin for Supabase integration with server and TUI components",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/supabase-community/opencode-supabase.git"
  },
  "main": "./index.ts",
  "exports": {
    "./server": "./src/server/index.ts",
    "./tui": "./src/tui/index.tsx"
  },
  "files": [
    "src/",
    "skills/",
    "index.ts",
    "README.md"
  ],
  "oc-plugin": [
    "server",
    "tui"
  ],
  "scripts": {
    "lint": "biome check .",
    "verify:pack": "npm pack --dry-run",
    "skills:sync": "bun scripts/sync-agent-skills.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test --preload @opentui/solid/preload",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "release:beta": "bun scripts/release-beta.ts"
  },
  "dependencies": {
    "@opencode-ai/plugin": "latest",
    "@opencode-ai/sdk": "latest",
    "@opentui/core": "0.3.4",
    "@opentui/solid": "0.3.4",
    "open": "latest",
    "solid-js": "1.9.12",
    "zod": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.30.0",
    "@types/bun": "latest",
    "@types/node": "latest",
    "typescript": "^5"
  }
}
